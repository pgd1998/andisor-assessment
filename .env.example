# ─────────────────────────────────────────────────────────────────────────────
# Andisor Inventory Platform — environment reference
# Copy to `.env` (`cp .env.example .env`) before running `docker compose up`.
# Every value below has a sane default baked into docker-compose.yml; override here.
# ─────────────────────────────────────────────────────────────────────────────

# ── PostgreSQL ──────────────────────────────────────────────────────────────
POSTGRES_USER=andisor
POSTGRES_PASSWORD=andisor_dev_password
POSTGRES_DB=andisor
POSTGRES_PORT=5432

# ── Redis (BullMQ backing store) ────────────────────────────────────────────
REDIS_PORT=6379

# ── Backend API ─────────────────────────────────────────────────────────────
API_PORT=4000
NODE_ENV=development
LOG_LEVEL=info
# Connection string consumed by Prisma. When running the API *outside* Docker,
# swap `postgres`/`redis` hostnames for `localhost`.
DATABASE_URL=postgresql://andisor:andisor_dev_password@postgres:5432/andisor?schema=public
REDIS_URL=redis://redis:6379
# Comma-separated list of origins allowed by CORS.
CORS_ORIGIN=http://localhost:5173,http://localhost:8080
# Requests per window (per IP) for the global rate limiter.
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX=300
# Max bulk-import upload size in bytes (default 5 MB).
BULK_IMPORT_MAX_FILE_BYTES=5242880

# ── Frontend ────────────────────────────────────────────────────────────────
FRONTEND_PORT=8080
# Base URL the browser uses to reach the API. In Docker the frontend's nginx
# proxies /api to the api service, so this stays relative.
VITE_API_BASE_URL=/api
