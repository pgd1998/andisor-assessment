# Test environment (committed — contains no secrets, only local test config).
# The e2e tests run against a SEPARATE database (`andisor_test`) so they can
# freely truncate tables without touching the app's data. Values here override
# `.env` when running the test suite.
#
# Ports match the docker-compose defaults (5432/6379). If you override
# POSTGRES_PORT / REDIS_PORT in `.env`, update the URLs below to match.

NODE_ENV=test
DATABASE_URL=postgresql://andisor:andisor_dev_password@localhost:5432/andisor_test?schema=public
REDIS_URL=redis://localhost:6379/1
LOG_LEVEL=silent
